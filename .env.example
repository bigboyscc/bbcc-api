# Server Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
SERVICE_NAME=bbcc-api

# Database - MongoDB
DATABASE_URL=mongodb://localhost:27017/bbcc
# For MongoDB Atlas:
# DATABASE_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/bbcc?retryWrites=true&w=majority

# CORS - Frontend URLs
FRONTEND_URL=http://localhost:3000

# JWT Configuration (for authentication)
JWT_ACCESS_SECRET=your-access-secret-key-here-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-here-change-this-in-production
